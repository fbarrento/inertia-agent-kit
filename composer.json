{
    "name": "fbarrento/inertia-agent-kit",
    "description": "AI-native convention, feedback, audit, and verification kit for Laravel Inertia frontends.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "agent",
        "inertia",
        "laravel",
        "testing",
        "ui"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pao": "^1.0",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.6.3",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.4"
    },
    "suggest": {
        "laravel/boost": "Discovers package-provided Inertia Agent Kit guidelines and skills for Laravel-aware agents."
    },
    "autoload": {
        "psr-4": {
            "InertiaAgentKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "InertiaAgentKit\\InertiaAgentKitServiceProvider"
            ]
        }
    },
    "scripts": {
        "lint": [
            "rector",
            "pint --parallel"
        ],
        "test:type-coverage": "env __PEST_PLUGIN_ENV=1 pest --type-coverage --min=100",
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run"
        ],
        "test:unit": "XDEBUG_MODE=\"coverage\" pest --parallel --coverage --exactly=100.0",
        "test:types": "phpstan",
        "test": [
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
